# --- Stripe (https://dashboard.stripe.com/apikeys) ---
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Created after you set up the webhook endpoint (see README)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Vercel Blob (Storage tab in your Vercel project -> Create Blob store) ---
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# --- Resend (https://resend.com/api-keys) — for sending you the order email ---
RESEND_API_KEY=re_xxx
# Must be an address on a domain you've verified in Resend
EMAIL_FROM="MixMaster Studio <orders@yourdomain.com>"
NOTIFY_EMAIL=Kalebmay18@gmail.com
# Optional: disable email notifications and use Stripe + Blob only
DISABLE_EMAIL_NOTIFICATIONS=false

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin dashboard (/admin) ---
# Password to log into /admin. Pick something strong.
ADMIN_PASSWORD=change-me
# Random string used to sign the admin login session cookie.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=change-me-too
